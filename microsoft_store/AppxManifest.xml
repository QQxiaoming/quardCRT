<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap rescap">

  <Identity
    Name="Quard.Qiao.quardCRTBeta"
    Publisher="PUBLISHER_PLACEHOLDER"
    Version="VERSION_PLACEHOLDER"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>quardCRT</DisplayName>
    <PublisherDisplayName>PUBLISHER_DISPLAY_NAME_PLACEHOLDER</PublisherDisplayName>
    <Logo>Assets\StoreLogo.scale-100.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
  </Dependencies>

  <Resources>
    <Resource Language="x-generate" />
  </Resources>

  <Applications>
    <Application
      Id="quardCRT"
      Executable="VFS\ProgramFilesX86\quardCRT\quardCRT.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="quardCRT"
        Description="quardCRT is a versatile serial port terminal tool"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\QUARDCRT-Square150x150Logo.scale-100.png"
        Square44x44Logo="Assets\QUARDCRT-Square44x44Logo.scale-100.png">
        <uap:DefaultTile
          ShortName="quardCRT"
          Square71x71Logo="Assets\QUARDCRT-Square71x71Logo.scale-100.png"
          Square310x310Logo="Assets\QUARDCRT-Square310x310Logo.scale-100.png"
          Wide310x150Logo="Assets\QUARDCRT-Wide310x150Logo.scale-100.png">
        </uap:DefaultTile>
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

</Package>
